# ===== СКОПИРУЙ В .env И ЗАПОЛНИ =====

# Сервер
PORT=3000
NODE_ENV=production

# JWT секрет — замени на длинную случайную строку!
JWT_SECRET=замени_на_случайную_строку_минимум_32_символа

# База данных (путь к файлу SQLite)
DB_PATH=./artwin.db

# Email (Gmail SMTP)
# Важно: включи "Двухфакторную аутентификацию" в Google-аккаунте,
# затем создай "Пароль приложения" на https://myaccount.google.com/apppasswords
GMAIL_USER=твоя.почта@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Название отправителя
EMAIL_FROM=ArtWin <твоя.почта@gmail.com>

# URL сайта (для ссылок в письмах)
SITE_URL=https://artwin.live

# Загрузка файлов
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10
